# ==============================================================================
# autorunclaude config
# Copy to .env and fill in real values
# ==============================================================================

# --- Telegram ---
# Get token from @BotFather on Telegram (steps in docs/setup-guide.md)
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to send commands
# Find your ID by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_USER_IDS=

# Optional: comma-separated Telegram chat IDs (groups) allowed
# Find chat ID by adding bot to group, then visit:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_ALLOWED_CHAT_IDS=

# --- Claude Code ---
# Path to claude CLI. Leave empty to use "claude" from PATH.
CLAUDE_CLI_PATH=

# Working directory the agent operates in.
# Defaults to process.cwd() if empty.
CLAUDE_WORK_DIR=

# Permission mode: bypassPermissions | acceptEdits | default | plan
# bypassPermissions = full access (no prompts). User requested this.
CLAUDE_PERMISSION_MODE=bypassPermissions

# Model alias: opus | sonnet | haiku, or full model name. Empty = default.
CLAUDE_MODEL=

# Effort level: low | medium | high | xhigh | max. Empty = default.
CLAUDE_EFFORT=

# Max minutes a single claude subprocess can run before being killed
CLAUDE_TIMEOUT_MINUTES=30

# --- Channels (enable/disable) ---
ENABLE_TERMINAL_CHANNEL=true
ENABLE_TELEGRAM_CHANNEL=true

# --- Session behavior ---
# shared = all users in same channel share 1 session
# per-user = each Telegram user has own session
SESSION_MODE=per-user

# --- Proactive triggers (cron) ---
# JSON array of { name, cron, prompt } objects, OR path to a JSON file
# Example: [{"name":"morning-check","cron":"0 9 * * *","prompt":"Check overnight logs"}]
PROACTIVE_TRIGGERS=

# Where to notify proactive trigger results: terminal | telegram | both
PROACTIVE_NOTIFY=telegram

# --- Logging ---
LOG_LEVEL=info
